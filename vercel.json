{
  "build": {
    "command": "HUGO_VERSION=0.146.0 && curl -sL https://github.com/gohugoio/hugo/releases/download/v${HUGO_VERSION}/hugo_extended_${HUGO_VERSION}_linux-amd64.tar.gz | tar -xz && chmod +x hugo && ./hugo --gc --minify",
    "env": {
      "HUGO_VERSION": "0.146.0"
    }
  },
  "outputDirectory": "public"
}
